# Copy this to `.env` on the VPS (docker-compose reads `.env` for both build
# args and runtime). `.env` is gitignored — it does not travel with `git pull`.

# App URL — used for password-reset links. Production = the public domain.
APP_URL=https://foodtruck.businessfalkenberg.se
NEXT_PUBLIC_APP_URL=https://foodtruck.businessfalkenberg.se

# Directus CMS URL (the backend lives on the same VPS, public via Caddy)
DIRECTUS_URL=https://cms.businessfalkenberg.se
NEXT_PUBLIC_DIRECTUS_URL=https://cms.businessfalkenberg.se

# Google Maps — NEXT_PUBLIC_* is inlined at build time.
# This key must allow the foodtruck.businessfalkenberg.se HTTP referrer in
# Google Cloud Console (APIs & Services -> Credentials -> referrer restrictions).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAP_ID=DEMO_MAP_ID
